{% extends 'base.html.twig' %}

{% block title %}Kevin Libaude | Concepteur & développeur d'application{% endblock %}

{% block body %}
    {% set method_lead = {
        label: 'Cadence',
        title: 'Un cadre clair pour avancer sans lourdeur',
        description: "On part du besoin, on structure l'idée, puis on livre une première version utile avant de la faire évoluer avec les usages réels.",
        image: '/images/home/method-lead.jpg',
        image_alt: 'Poste de travail sobre avec ordinateur portable, carnet et lumière naturelle pour illustrer une méthode claire et structurée.'
    } %}
    {% set method_images = {
        '01': {
            image: '/images/home/method-step-01.jpg',
            alt: 'Équipe en atelier devant un tableau pour cadrer un besoin et organiser les premières idées.'
        },
        '02': {
            image: '/images/home/method-step-02.jpg',
            alt: 'Croquis de wireframe sur papier pour structurer une interface avant le développement.'
        },
        '03': {
            image: '/images/home/method-step-03.jpg',
            alt: 'Développeur concentré devant son ordinateur portable pendant une phase de réalisation.'
        },
        '04': {
            image: '/images/home/method-step-04.jpg',
            alt: 'Ordinateur, carnet et café sur un poste de travail prêt pour une livraison propre et cadrée.'
        },
        '05': {
            image: '/images/home/method-step-05.jpg',
            alt: 'Tableau de bord analytique affiché sur un ordinateur pour suivre les usages et orienter les évolutions.'
        }
    } %}
    {% set contact_state = app.request.query.get('contact') %}
    {% set contact_success_messages = app.flashes('contact_success') %}
    {% set contact_error_messages = app.flashes('contact_error') %}
    {% set has_contact_feedback = contact_state in ['success', 'error'] or (contact_success_messages|length + contact_error_messages|length) > 0 %}
    <div class="site-shell">
        <header class="site-header">
            <a class="brand" href="{{ path('app_home') }}">
                <span class="brand-mark">KL</span>
                <span>
                    <strong>{{ identity.name }}</strong>
                    <small>{{ identity.role }}</small>
                </span>
            </a>

            <nav class="site-nav" aria-label="Navigation principale">
                <a href="#services">Services</a>
                <a href="#methode">Méthode</a>
                <a href="#realisations">Réalisations</a>
                <a href="#a-propos">À propos</a>
                <a href="#contact">Contact</a>
            </nav>

            <a class="button button-outline" href="#contact">Parlons de votre projet</a>
        </header>

        <main>
            <section class="hero section">
                <div class="hero-copy">
                    <p class="eyebrow">Direction créative & stratégique</p>
                    <h1>{{ identity.promise }}</h1>
                    <p class="hero-text">{{ identity.subtitle }}</p>

                    <div class="hero-actions">
                        <a class="button" href="#contact">Parlons de votre projet</a>
                        <a class="button button-ghost" href="#realisations">Voir mes réalisations</a>
                    </div>

                    <ul class="hero-points">
                        <li>Applications web sur mesure</li>
                        <li>Outils métier et automatisation</li>
                        <li>Accompagnement de la conception à la livraison</li>
                    </ul>
                </div>

                <div class="hero-visual" aria-hidden="true">
                    <div class="visual-grid"></div>
                    <div class="visual-node node-a"></div>
                    <div class="visual-node node-b"></div>
                    <div class="visual-node node-c"></div>
                    <div class="visual-node node-d"></div>
                    <div class="visual-line line-a"></div>
                    <div class="visual-line line-b"></div>
                    <div class="visual-line line-c"></div>
                    <div class="visual-card visual-card-a">
                        <span>Besoin</span>
                        <strong>Clarifier</strong>
                    </div>
                    <div class="visual-card visual-card-b">
                        <span>Conception</span>
                        <strong>Structurer</strong>
                    </div>
                    <div class="visual-card visual-card-c">
                        <span>Livraison</span>
                        <strong>Faire vivre</strong>
                    </div>
                </div>
            </section>

            <section id="services" class="section">
                <div class="section-heading">
                    <p class="eyebrow">Services</p>
                    <h2>Ce que je peux construire avec vous</h2>
                    <p>Chaque projet commence par un besoin concret : gagner du temps, mieux organiser une activité, moderniser un outil ou créer une solution dédiée.</p>
                </div>

                <div class="services-flow">
                    <div class="services-intro">
                        <p class="panel-label">Approche</p>
                        <h3>Moins de catalogue, plus de trajectoire</h3>
                        <p>Chaque intervention part d'une situation réelle, puis se transforme en outil, en interface et en solution durable.</p>
                    </div>

                    <div class="services-stack">
                        {% for service in services %}
                            <article class="service-band">
                                <p class="service-kicker">0{{ loop.index }} / besoin</p>
                                <div class="service-band-body">
                                    <h3>{{ service.title }}</h3>
                                    <p>{{ service.description }}</p>
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                </div>
            </section>

            <section id="methode" class="section">
                <div class="section-heading">
                    <p class="eyebrow">Méthode</p>
                    <h2>Une méthode simple, claire et progressive</h2>
                    <p>L'objectif est d'avancer étape par étape, sans complexifier inutilement le projet.</p>
                </div>

                <div class="method-flow">
                    <article class="method-lead">
                        <div class="method-lead-visual">
                            <img
                                src="{{ method_lead.image }}"
                                alt="{{ method_lead.image_alt }}"
                                loading="lazy"
                                decoding="async"
                                width="1200"
                                height="1799"
                            >
                        </div>
                        <p class="panel-label">{{ method_lead.label }}</p>
                        <h3>{{ method_lead.title }}</h3>
                        <p>{{ method_lead.description }}</p>
                    </article>

                    <div class="method-rail" data-controller="method-stack" data-method-stack-visible-count-value="3">
                        <div class="method-steps-stack">
                            {% for step in steps %}
                                {% set step_image = method_images[step.index] ?? null %}
                                <article
                                    class="method-step"
                                    data-method-stack-target="step"
                                    data-action="click->method-stack#advance keydown.enter->method-stack#advance keydown.space->method-stack#advance"
                                    tabindex="0"
                                >
                                    <p class="method-step-index">{{ step.index }}</p>
                                    <div class="method-step-body">
                                        {% if step_image %}
                                            <div class="method-step-visual">
                                                <img
                                                    src="{{ step_image.image }}"
                                                    alt="{{ step_image.alt }}"
                                                    loading="lazy"
                                                    decoding="async"
                                                    width="1200"
                                                    height="{% if step.index == '03' %}819{% elseif step.index == '04' %}810{% else %}800{% endif %}"
                                                >
                                            </div>
                                        {% endif %}
                                        <h3>{{ step.title }}</h3>
                                        <p>{{ step.description }}</p>
                                    </div>
                                </article>
                            {% endfor %}
                        </div>

                        <button class="method-stack-button" type="button" data-action="method-stack#advance">
                            Étape suivante
                        </button>
                    </div>
                </div>
            </section>

            <section id="realisations" class="section">
                <div class="section-heading">
                    <p class="eyebrow">Réalisations</p>
                    <h2>Des projets pensés pour répondre à un besoin réel</h2>
                    <p>Chaque réalisation est présentée comme une réponse à un problème concret, pas comme une simple liste de technologies.</p>
                </div>

                <div class="project-showcase">
                    {% for project in projects %}
                        <article
                            class="project-story{% if project.image %} project-story-with-image{% endif %}"
                            {% if project.image %}style="--project-image: url('{{ project.image }}');"{% endif %}
                        >
                            <div class="project-story-meta">
                                <p class="project-story-index">0{{ loop.index }}</p>
                                <p class="project-type">{{ project.type }}</p>
                            </div>

                            <div class="project-story-body">
                                <div class="project-story-heading">
                                    <h3>{{ project.name }}</h3>
                                    <p>{{ project.summary }}</p>
                                </div>

                                <div class="project-story-track" aria-hidden="true"></div>

                                <div class="project-story-points">
                                    <div>
                                        <span>Problème</span>
                                        <p>{{ project.problem }}</p>
                                    </div>
                                    <div>
                                        <span>Solution</span>
                                        <p>{{ project.solution }}</p>
                                    </div>
                                </div>
                            </div>

                            <a class="text-link" href="{{ path('app_project_show', { slug: project.slug }) }}">Explorer le projet</a>
                        </article>
                    {% endfor %}
                </div>
            </section>

            <section class="section section-split">
                <div id="expertises">
                    <div class="section-heading compact">
                        <p class="eyebrow">Expertises</p>
                    <h2>Des compétences au service de solutions utiles</h2>
                    </div>

                    <div class="expertise-list">
                        {% for expertise in expertises %}
                            <article class="expertise-row">
                                <h3>{{ expertise.title }}</h3>
                                <p>{{ expertise.description }}</p>
                            </article>
                        {% endfor %}
                    </div>
                </div>

                <aside id="a-propos" class="about-panel">
                    <p class="eyebrow">À propos</p>
                    <h2>Concevoir utile, développer durable</h2>
                    <p>Je conçois des solutions numériques avec une idée simple : un bon outil doit répondre à un vrai besoin, rester compréhensible pour ses utilisateurs et pouvoir évoluer dans le temps.</p>
                    <p>Mon parcours mêle développement web, conception d'applications, gestion de projet et expérience terrain auprès des utilisateurs.</p>

                    <div class="mindmap">
                        <div>
                            <span>Humain</span>
                            <small>Comprendre - Écouter - Accompagner</small>
                        </div>
                        <div>
                            <span>Produit</span>
                            <small>Organiser - Prioriser - Concevoir</small>
                        </div>
                        <div>
                            <span>Technique</span>
                            <small>Développer - Maintenir - Faire évoluer</small>
                        </div>
                    </div>
                </aside>
            </section>

            <div class="contact-entry">
                {% if has_contact_feedback %}
                    <div class="contact-page-feedback{% if contact_state == 'error' or contact_error_messages is not empty %} contact-page-feedback-error{% else %} contact-page-feedback-success{% endif %}">
                        <span class="contact-page-feedback-label">
                            {% if contact_state == 'error' or contact_error_messages is not empty %}
                                Envoi impossible
                            {% else %}
                                Message envoye
                            {% endif %}
                        </span>
                        {% if contact_state == 'success' and contact_success_messages is empty %}
                            <p>Votre message a bien ete envoye depuis le site.</p>
                        {% elseif contact_state == 'error' and contact_error_messages is empty %}
                            <p>Le message n a pas pu etre envoye pour le moment.</p>
                        {% elseif contact_success_messages is not empty %}
                            <p>{{ contact_success_messages|first }}</p>
                        {% elseif contact_error_messages is not empty %}
                            <p>{{ contact_error_messages|first }}</p>
                        {% endif %}
                    </div>
                {% endif %}

                <section id="contact" class="section contact-band">
                    <div class="contact-copy">
                        <p class="eyebrow">Contact</p>
                        <h2>On peut partir d'une idée floue et la transformer en plan d'action clair.</h2>
                        <p>Que votre besoin soit déjà cadré ou encore en réflexion, l'objectif est d'identifier rapidement ce qu'il faut construire, dans quel ordre et avec quel niveau d'ambition.</p>

                        <div class="contact-highlights">
                            <div>
                                <span>Premier échange</span>
                                <strong>Simple et direct</strong>
                            </div>
                            <div>
                                <span>Point de départ</span>
                                <strong>Besoin, contexte, priorités</strong>
                            </div>
                        </div>
                    </div>

                    <div class="contact-actions">
                        <div
                            class="contact-card{% if has_contact_feedback %} is-open{% endif %}"
                            data-controller="contact-reveal"
                            data-contact-reveal-open-on-connect-value="{{ has_contact_feedback ? 'true' : 'false' }}"
                        >
                            <p class="contact-card-label">Prise de contact</p>
                            <button
                                class="button"
                                type="button"
                                data-action="contact-reveal#toggle"
                                data-contact-reveal-target="trigger"
                                aria-expanded="false"
                            >
                                Afficher le formulaire
                            </button>
                            <p>Quelques informations suffisent pour poser le contexte, le besoin et les premières questions.</p>

                            <div class="contact-form-shell" data-contact-reveal-target="panel" aria-hidden="{{ has_contact_feedback ? 'false' : 'true' }}" {% if not has_contact_feedback %}inert{% endif %}>
                                <div class="contact-form-shell-inner">
                                    <form class="contact-form" method="post" action="{{ path('app_contact_send') }}" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('contact_form') }}">
                                        <div class="contact-form-grid">
                                            <label class="contact-field">
                                                <span>Nom</span>
                                                <input type="text" name="name" autocomplete="name" data-contact-reveal-target="firstField" required>
                                            </label>

                                            <label class="contact-field">
                                                <span>Email</span>
                                                <input type="email" name="email" autocomplete="email" required>
                                            </label>
                                        </div>

                                        <label class="contact-field">
                                            <span>Projet</span>
                                            <input type="text" name="project" placeholder="Refonte, outil métier, site vitrine...">
                                        </label>

                                        <label class="contact-field">
                                            <span>Message</span>
                                            <textarea name="message" rows="5" placeholder="Quelques lignes sur votre besoin, votre contexte ou vos priorités." required></textarea>
                                        </label>

                                        <div class="contact-form-actions">
                                            <button class="button" type="submit">Envoyer le message</button>
                                        </div>

                                        <p class="contact-form-note">Le message est envoyé directement depuis le site.</p>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <div class="contact-links">
                            <a href="https://www.linkedin.com/in/kevin-libaude-5540616b/" target="_blank" rel="noreferrer">
                                <span>LinkedIn</span>
                                <strong>Échanger sur le projet</strong>
                            </a>
                            <a href="https://github.com/KevinLibaude" target="_blank" rel="noreferrer">
                                <span>GitHub</span>
                                <strong>Voir l'univers technique</strong>
                            </a>
                        </div>
                    </div>
                </section>
            </div>
        </main>
        <br/>
        <footer class="site-footer">
            <div>
                <strong>{{ identity.name }}</strong>
                <p>{{ identity.role }}</p>
            </div>
            <p>Portfolio freelance construit avec Symfony.</p>
        </footer>
    </div>
{% endblock %}
