{% extends 'base.html.twig' %}

{% block title %}{{ project.name }} | Kevin Libaude{% endblock %}

{% block body %}
    <div class="site-shell">
        <header class="site-header">
            <a class="brand" href="{{ path('app_home') }}">
                <span class="brand-mark">KL</span>
                <span>
                    <strong>{{ identity.name }}</strong>
                    <small>{{ identity.role }}</small>
                </span>
            </a>

            <a class="button button-outline project-back-link" href="{{ path('app_home') }}#realisations">Retour aux realisations</a>
        </header>

        <main class="project-page">
            <section class="section project-hero">
                <div class="project-hero-primary">
                    {% if project.image %}
                        <figure class="project-shot">
                            <img
                                src="{{ project.image }}"
                                alt="Apercu du projet {{ project.name }}"
                                decoding="async"
                                width="4460"
                                height="2786"
                            >
                        </figure>
                    {% else %}
                        <article class="project-hero-panel project-hero-placeholder" aria-hidden="true">
                            <p class="panel-label">Vue d ensemble</p>
                            <h2>{{ project.name }}</h2>
                            <p>{{ project.type }}</p>
                        </article>
                    {% endif %}
                </div>

                <aside class="project-overview project-hero-copy">
                    <article class="project-summary-card project-summary-card-hero">
                        <p class="panel-label">{{ project.status }}</p>
                        <p class="project-intro-type">{{ project.type }}</p>
                        <h2>{{ project.name }}</h2>
                        <p>{{ project.summary }}</p>
                    </article>

                    {% if project.links is not empty %}
                        <div class="hero-actions">
                            {% for link in project.links %}
                                <a class="button" href="{{ link.url }}" target="_blank" rel="noreferrer">{{ link.label }}</a>
                            {% endfor %}
                        </div>
                    {% endif %}
                </aside>
            </section>

            <section class="section">
                <div class="section-heading compact">
                    <p class="eyebrow">Lecture rapide</p>
                    <h2>Les points cles du projet</h2>
                </div>

                <div class="project-summary-points project-summary-points-grid">
                    <div>
                        <span>Probleme</span>
                        <p>{{ project.problem }}</p>
                    </div>
                    <div>
                        <span>Defi</span>
                        <p>{{ project.challenge }}</p>
                    </div>
                    <div>
                        <span>Solution</span>
                        <p>{{ project.solution }}</p>
                    </div>
                    <div>
                        <span>Impact</span>
                        <p>{{ project.result }}</p>
                    </div>
                </div>
            </section>

            {% if project.before_after is defined %}
                <section class="section">
                    <div class="section-heading compact">
                        <p class="eyebrow">{{ project.before_after.eyebrow }}</p>
                        <h2>{{ project.before_after.title }}</h2>
                    </div>

                    <div class="project-before-after">
                        <article class="project-state-card">
                            <p class="panel-label">{{ project.before_after.before.label }}</p>
                            <p>{{ project.before_after.before.text }}</p>
                        </article>

                        <article class="project-state-card project-state-card-accent">
                            <p class="panel-label">{{ project.before_after.after.label }}</p>
                            <p>{{ project.before_after.after.text }}</p>
                        </article>
                    </div>
                </section>
            {% endif %}

            {% if project.constraints is defined %}
                <section class="section">
                    <div class="section-heading compact">
                        <p class="eyebrow">{{ project.constraints.eyebrow }}</p>
                        <h2>{{ project.constraints.title }}</h2>
                    </div>

                    <div class="project-editorial-grid">
                        {% for item in project.constraints.items %}
                            <article class="project-editorial-card">
                                <h3>{{ item.title }}</h3>
                                <p>{{ item.description }}</p>
                            </article>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

            {% if project.decisions is defined %}
                <section class="section">
                    <div class="section-heading compact">
                        <p class="eyebrow">{{ project.decisions.eyebrow }}</p>
                        <h2>{{ project.decisions.title }}</h2>
                    </div>

                    <div class="project-decision-flow">
                        {% for item in project.decisions.items %}
                            <article class="project-decision-card">
                                <p class="project-decision-index">0{{ loop.index }}</p>
                                <div class="project-decision-body">
                                    <h3>{{ item.title }}</h3>
                                    <p>{{ item.description }}</p>
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

            {% if project.delivery is defined %}
                <section class="section">
                    <div class="section-heading compact">
                        <p class="eyebrow">{{ project.delivery.eyebrow }}</p>
                        <h2>{{ project.delivery.title }}</h2>
                    </div>

                    <div class="feature-list">
                        {% for item in project.delivery.items %}
                            <article class="feature-row">
                                <h3>{{ item.title }}</h3>
                                <p>{{ item.description }}</p>
                            </article>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

            <section class="section project-layout">
                {% for section in project.sections %}
                    <article class="project-chapter">
                        <p class="project-chapter-index">0{{ loop.index }}</p>
                        <div class="project-chapter-body">
                            <p class="panel-label">{{ section.label }}</p>
                            <h2>{{ section.title }}</h2>
                            <p>{{ section.content }}</p>
                        </div>
                    </article>
                {% endfor %}
            </section>

            {% for list in project.list_sections %}
                <section class="section">
                    <div class="section-heading compact">
                        <p class="eyebrow">{{ list.eyebrow }}</p>
                        <h2>{{ list.title }}</h2>
                    </div>

                    {% if list.variant == 'cards' %}
                        <div class="feature-list">
                            {% for item in list.items %}
                                <article class="feature-row">
                                    <h3>{{ item.title }}</h3>
                                    <p>{{ item.description }}</p>
                                </article>
                            {% endfor %}
                        </div>
                    {% endif %}
                </section>
            {% endfor %}

            {% if project.outcomes is defined %}
                <section class="section">
                    <div class="section-heading compact">
                        <p class="eyebrow">{{ project.outcomes.eyebrow }}</p>
                        <h2>{{ project.outcomes.title }}</h2>
                    </div>

                    <div class="project-outcomes-grid">
                        {% for item in project.outcomes.items %}
                            <article class="project-outcome-card">
                                <p class="panel-label">{{ item.label }}</p>
                                <p class="project-outcome-value">{{ item.value }}</p>
                            </article>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

            {% if project.stack_details is defined %}
                <section class="section">
                    <div class="section-heading compact">
                        <p class="eyebrow">{{ project.stack_details.eyebrow }}</p>
                        <h2>{{ project.stack_details.title }}</h2>
                    </div>

                    <div class="project-stack-story">
                        {% for item in project.stack_details.items %}
                            <article class="project-stack-card">
                                <h3>{{ item.name }}</h3>
                                <p>{{ item.role }}</p>
                            </article>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

            <section class="section">
                <div class="section-heading compact">
                    <p class="eyebrow">Stack</p>
                    <h2>Quelques briques mobilisees</h2>
                </div>

                <div class="tag-row">
                    {% for item in project.stack %}
                        <span class="tag">{{ item }}</span>
                    {% endfor %}
                </div>
            </section>

        </main>
    </div>
{% endblock %}
